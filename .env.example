# ---------------------------------------------------------------
# moodle-sync environment configuration
# Copy this file to .env and fill in your values.
# .env is listed in .gitignore and will NEVER be committed.
# ---------------------------------------------------------------

# Required: absolute path to the folder where Moodle content will be synced.
# The directory must already exist and be writable.
MOODLE_SYNC_PATH=/path/to/your/sync/folder

# Optional: Moodle API token (avoids typing it on every --init / --new-token run).
# Obtain via: moodle-dl --init   or   moodle-dl --new-token
# If set, this is equivalent to passing --token on the CLI.
# MOODLE_TOKEN=your_moodle_token_here

# Optional: credentials used only during token generation (never stored).
# Equivalent to --username / --password CLI flags.
# WARNING: storing a password in a file is less secure than typing it interactively.
# Only use these for automated / headless environments and keep .env permissions tight (chmod 600 .env).
# MOODLE_USERNAME=your_username
# MOODLE_PASSWORD=your_password
