# ---------------------------------------------------------------
# moodle-sync environment configuration
# Copy this file to .env and fill in your values.
# .env is listed in .gitignore and will NEVER be committed.
# ---------------------------------------------------------------

# ---- Canvas sync (canvas_sync.py) ----

# Base URL of your Canvas instance
CANVAS_URL=https://your-canvas-instance.edu

# Course ID from the URL: /courses/<id>
CANVAS_COURSE_ID=12345

# Absolute path to the folder where course content will be synced.
# Sub-folders are created per module/week automatically.
CANVAS_SYNC_PATH=/path/to/your/sync/folder

# Path to your browser cookies file (Netscape format, exported via browser extension).
# See README for instructions on exporting cookies.
CANVAS_COOKIES_FILE=cookies.txt


# ---- Moodle-DL (original tool, if used) ----

# MOODLE_SYNC_PATH=/path/to/moodle/sync/folder
# MOODLE_TOKEN=your_moodle_token_here
# MOODLE_USERNAME=your_username
# MOODLE_PASSWORD=your_password
